---
import QuoteSummary from "./QuoteSummary.astro";
import InfoContact from "./InfoContact.astro";
import DetailsProyect from "./DetailsProyect.astro";
import AddServices from "./AddServices.astro";

---
<div class="flex flex-col items-center justify-center size-full p-3" id="quote-modal-container">

    <div class="overflow-y-auto max-w-4xl w-full rounded-2xl border border-white/10 md:flex bg-background divide-x divide-y divide-white/10">
        
        <!-- Summary -->
        <div class="w-full md:w-xl">
            <QuoteSummary />
        </div>
        
        <!-- Details -->
        <div class="w-full relative">

            <!-- Step 1 -->
            <div class="step-content active" data-step-content="1">
                <InfoContact />
            </div>

            <!-- Step 2 -->
            <div class="step-content" data-step-content="2">
                <DetailsProyect />
            </div>

            <!-- Step 3 -->
            <div class="step-content" data-step-content="3">
                <AddServices />
            </div>
        </div>
    </div>    

</div>

<style>
    /* Step Content Styles */
    .step-content {
        display: none;
    }

    .step-content.active {
        display: block;
        animation: fadeIn 0.5s ease-in-out;
    }

    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateX(10px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }
</style>

<script>
    // State management for quote
    interface QuoteItem {
        type: 'plan' | 'service';
        name: string;
        price: number | null;
        priceLabel: string;
    }

    interface SelectedPlan {
        serviceId: string;
        serviceTitle: string;
        level: string;
        price: number | null;
        priceLabel: string;
    }

    function formatSoles(price: number) {
        return `S/. ${price.toLocaleString('es-PE')}`;
    }

    class QuoteManager {
        private items: QuoteItem[] = [];
        private selectedPlan: SelectedPlan | null = null;
        private quoteItemsContainer: HTMLElement | null;
        private quoteTotalElement: HTMLElement | null;

        constructor() {
            this.quoteItemsContainer = document.getElementById('quote-items');
            this.quoteTotalElement = document.getElementById('quote-total');
            this.init();
        }

        init() {
            // Listen to all pricing card buttons
            document.addEventListener('click', (e) => {
                const target = e.target as HTMLElement;
                const button = target.closest('.pricing-select-btn') as HTMLElement;
                
                if (button) {
                    const level = button.getAttribute('data-plan-level') || '';
                    const priceValue = button.getAttribute('data-plan-price-value') || '';
                    const priceLabel = button.getAttribute('data-plan-price-label') || '$0';
                    const description = button.getAttribute('data-plan-description') || '';
                    const serviceId = button.getAttribute('data-service-id') || '';
                    const serviceTitle = button.getAttribute('data-service-title') || 'Servicio';
                    
                    this.selectPlan(level, priceValue, priceLabel, description, serviceId, serviceTitle);
                }
            });
        }

        selectPlan(level: string, priceValue: string, priceLabel: string, description: string, serviceId: string, serviceTitle: string) {
            // Reset everything when selecting a new plan
            this.reset();
            
            const parsedPrice = parseFloat(priceValue);
            const price = isNaN(parsedPrice) ? null : parsedPrice;
            const normalizedPriceLabel = price === null ? priceLabel : formatSoles(price);
            this.selectedPlan = {
                serviceId,
                serviceTitle,
                level,
                price,
                priceLabel: normalizedPriceLabel,
            };
            
            // Add new plan
            this.items.unshift({
                type: 'plan',
                name: `${serviceTitle} - Plan ${level}`,
                price,
                priceLabel: normalizedPriceLabel,
            });

            this.updateUI();
            setSubmitStatus('', 'neutral');
            
            // Reset step to 1
            if ((window as any).stepManager) {
                (window as any).stepManager.reset();
            }
            
            // Load additional services for the selected quote type
            if ((window as any).setAdditionalServicesForService) {
                (window as any).setAdditionalServicesForService(serviceId);
            } else if ((window as any).resetServices) {
                (window as any).resetServices();
            }

            // Reset forms
            this.resetForms();
        }

        resetForms() {
            // Reset contact form
            const contactForm = document.getElementById('contact-form') as HTMLFormElement;
            if (contactForm) {
                contactForm.reset();
            }

            // Reset project form
            const projectForm = document.getElementById('project-form') as HTMLFormElement;
            if (projectForm) {
                projectForm.reset();
            }
        }

        addService(name: string, price: number) {
            // Check if service already exists
            const existingIndex = this.items.findIndex(
                item => item.type === 'service' && item.name === name
            );

            if (existingIndex === -1) {
                this.items.push({
                    type: 'service',
                    name: name,
                    price,
                    priceLabel: formatSoles(price),
                });
            }

            this.updateUI();
        }

        removeService(name: string) {
            this.items = this.items.filter(
                item => !(item.type === 'service' && item.name === name)
            );
            this.updateUI();
        }

        updateUI() {
            if (!this.quoteItemsContainer || !this.quoteTotalElement) return;

            // Clear container
            this.quoteItemsContainer.innerHTML = '';

            if (this.items.length === 0) {
                this.quoteItemsContainer.innerHTML = `
                    <p class="text-neutral-400 italic col-span-2 text-center py-4">
                        Selecciona un plan para comenzar
                    </p>
                `;
                this.quoteTotalElement.textContent = formatSoles(0);
                return;
            }

            // Separate plan and services
            const plan = this.items.find(item => item.type === 'plan');
            const services = this.items.filter(item => item.type === 'service');

            // Render plan first
            if (plan) {
                const nameElement = document.createElement('p');
                nameElement.className = 'line-clamp-2';
                nameElement.textContent = plan.name;

                const priceElement = document.createElement('p');
                priceElement.className = 'font-semibold text-white text-end';
                priceElement.textContent = plan.priceLabel;

                this.quoteItemsContainer!.appendChild(nameElement);
                this.quoteItemsContainer!.appendChild(priceElement);
            }

            // Render services
            if (services.length === 0) {
                // No services
            } else if (services.length <= 2) {
                // Show individual services
                services.forEach(service => {
                    const nameElement = document.createElement('p');
                    nameElement.className = 'line-clamp-2';
                    nameElement.textContent = service.name;

                    const priceElement = document.createElement('p');
                    priceElement.className = 'font-semibold text-white text-end';
                    priceElement.textContent = service.priceLabel;

                    this.quoteItemsContainer!.appendChild(nameElement);
                    this.quoteItemsContainer!.appendChild(priceElement);
                });
            } else {
                // Show grouped services when more than 2
                const servicesTotal = services.reduce((sum, s) => sum + (s.price ?? 0), 0);
                
                const nameElement = document.createElement('p');
                nameElement.className = 'line-clamp-2';
                nameElement.textContent = `${services.length} servicios adicionales`;

                const priceElement = document.createElement('p');
                priceElement.className = 'font-semibold text-white text-end';
                priceElement.textContent = formatSoles(servicesTotal);

                this.quoteItemsContainer!.appendChild(nameElement);
                this.quoteItemsContainer!.appendChild(priceElement);
            }

            // Update total
            const total = this.items.reduce((sum, item) => sum + (item.price ?? 0), 0);
            this.quoteTotalElement.textContent = formatSoles(total);
        }

        getItems() {
            return this.items;
        }

        getLeadQuote() {
            const services = this.items.filter(item => item.type === 'service');
            const estimatedTotal = this.items.reduce((sum, item) => sum + (item.price ?? 0), 0);

            return {
                selectedPlan: this.selectedPlan,
                selectedAddOns: services.map((service) => ({
                    name: service.name,
                    price: service.price ?? 0,
                })),
                estimatedTotal,
            };
        }

        reset() {
            this.items = [];
            this.selectedPlan = null;
            this.updateUI();
        }
    }

    // Initialize quote manager
    const quoteManager = new QuoteManager();

    // Export to window for access from other components
    (window as any).quoteManager = quoteManager;

    // Step Navigation Manager
    class StepManager {
        private currentStep: number = 1;
        private totalSteps: number = 3;
        private stepIndicators: NodeListOf<Element>;
        private stepContents: NodeListOf<Element>;
        private stepLines: NodeListOf<Element>;
        private currentStepNumber: HTMLElement | null;

        constructor() {
            this.stepIndicators = document.querySelectorAll('.step-indicator');
            this.stepContents = document.querySelectorAll('.step-content');
            this.stepLines = document.querySelectorAll('.step-line');
            this.currentStepNumber = document.getElementById('current-step-number');
            this.attachEventListeners();
        }

        attachEventListeners() {
            // Listen for navigation from all forms
            document.addEventListener('click', (e) => {
                const target = e.target as HTMLElement;
                
                // Check if clicked element or its parent is a button
                const button = target.closest('button');
                if (!button) return;

                const buttonText = button.textContent?.trim().toLowerCase() || '';
                
                // Handle "Siguiente" buttons
                if (buttonText.includes('siguiente') || buttonText === '->') {
                    e.preventDefault();
                    this.nextStep();
                }
                // Handle "Anterior" buttons
                else if (buttonText.includes('anterior') || buttonText === '<-') {
                    e.preventDefault();
                    this.previousStep();
                }
            });
        }

        getCurrentStepForm() {
            if (this.currentStep === 1) {
                return document.getElementById('contact-form') as HTMLFormElement | null;
            }

            if (this.currentStep === 2) {
                return document.getElementById('project-form') as HTMLFormElement | null;
            }

            return null;
        }

        validateCurrentStep() {
            const currentForm = this.getCurrentStepForm();

            if (!currentForm) {
                return true;
            }

            const isValid = currentForm.reportValidity();

            if (!isValid) {
                const message = this.currentStep === 1
                    ? 'Completa tu nombre y correo antes de continuar.'
                    : 'Completa los detalles del proyecto antes de continuar.';

                setSubmitStatus(message, 'error');
                return false;
            }

            setSubmitStatus('', 'neutral');
            return true;
        }

        nextStep() {
            if (this.currentStep < this.totalSteps && this.validateCurrentStep()) {
                this.currentStep++;
                this.updateUI();
            }
        }

        previousStep() {
            if (this.currentStep > 1) {
                setSubmitStatus('', 'neutral');
                this.currentStep--;
                this.updateUI();
            }
        }

        goToStep(step: number) {
            if (step >= 1 && step <= this.totalSteps) {
                this.currentStep = step;
                this.updateUI();
            }
        }

        updateUI() {
            // Update step contents visibility
            this.stepContents.forEach((content, index) => {
                if (index + 1 === this.currentStep) {
                    content.classList.add('active');
                } else {
                    content.classList.remove('active');
                }
            });

            // Update step indicators
            this.stepIndicators.forEach((indicator, index) => {
                const stepNumber = index + 1;
                indicator.classList.remove('active', 'completed');
                
                if (stepNumber === this.currentStep) {
                    indicator.classList.add('active');
                } else if (stepNumber < this.currentStep) {
                    indicator.classList.add('completed');
                }
            });

            // Update lines
            this.stepLines.forEach((line, index) => {
                const lineNumber = index + 1;
                if (lineNumber < this.currentStep) {
                    line.classList.add('completed');
                } else {
                    line.classList.remove('completed');
                }
            });

            // Update step number text
            if (this.currentStepNumber) {
                this.currentStepNumber.textContent = this.currentStep.toString();
            }
        }

        getCurrentStep() {
            return this.currentStep;
        }

        reset() {
            this.currentStep = 1;
            this.updateUI();
        }
    }

    // Initialize step manager
    const stepManager = new StepManager();

    // Export to window for access from other components
    (window as any).stepManager = stepManager;

    const QUOTE_MODAL_ID = 'select-service-price-modal';

    function closeQuoteModal() {
        const modal = document.getElementById(QUOTE_MODAL_ID);

        if (!modal) {
            return;
        }

        if ((window as any).HSOverlay?.close) {
            (window as any).HSOverlay.close(modal);
            return;
        }

        modal.classList.add('hidden');
        modal.classList.remove('open', 'opened');
        modal.setAttribute('aria-expanded', 'false');
        document.body.classList.remove('overflow-hidden');
    }

    const quoteModalContainer = document.getElementById('quote-modal-container');

    quoteModalContainer?.addEventListener('mousedown', (event) => {
        if (event.target === event.currentTarget) {
            closeQuoteModal();
        }
    });

    const submitButton = document.getElementById('quote-submit-button') as HTMLButtonElement | null;
    const submitStatus = document.getElementById('quote-submit-status');

    function setSubmitStatus(message: string, type: 'neutral' | 'success' | 'error') {
        if (!submitStatus) {
            return;
        }

        submitStatus.textContent = message;
        submitStatus.classList.toggle('hidden', !message);
        submitStatus.classList.toggle('text-neutral-300', type === 'neutral');
        submitStatus.classList.toggle('text-green-400', type === 'success');
        submitStatus.classList.toggle('text-red-400', type === 'error');
    }

    function setSubmitting(isSubmitting: boolean) {
        if (!submitButton) {
            return;
        }

        submitButton.disabled = isSubmitting;
        submitButton.textContent = isSubmitting ? 'Enviando...' : 'Enviar';
        submitButton.classList.toggle('opacity-60', isSubmitting);
        submitButton.classList.toggle('cursor-not-allowed', isSubmitting);
    }

    function getFormValue(formData: FormData, key: string) {
        const value = formData.get(key);

        return typeof value === 'string' ? value.trim() : '';
    }

    function resetQuoteModal() {
        quoteManager.reset();
        stepManager.reset();
        quoteManager.resetForms();

        if ((window as any).resetServices) {
            (window as any).resetServices();
        }
    }

    async function submitLead() {
        const contactForm = document.getElementById('contact-form') as HTMLFormElement | null;
        const projectForm = document.getElementById('project-form') as HTMLFormElement | null;

        if (!contactForm || !projectForm) {
            setSubmitStatus('No se pudo leer el formulario. Inténtalo nuevamente.', 'error');
            return;
        }

        if (!contactForm.reportValidity() || !projectForm.reportValidity()) {
            setSubmitStatus('Completa los campos requeridos antes de enviar.', 'error');
            return;
        }

        const quote = quoteManager.getLeadQuote();

        if (!quote.selectedPlan) {
            setSubmitStatus('Selecciona un plan antes de enviar la cotización.', 'error');
            return;
        }

        const contactFormData = new FormData(contactForm);
        const projectFormData = new FormData(projectForm);
        const payload = {
            contact: {
                name: getFormValue(contactFormData, 'name'),
                company: getFormValue(contactFormData, 'company'),
                email: getFormValue(contactFormData, 'email'),
                phone: getFormValue(contactFormData, 'phone'),
            },
            quote: {
                serviceId: quote.selectedPlan.serviceId,
                serviceTitle: quote.selectedPlan.serviceTitle,
                planLevel: quote.selectedPlan.level,
                planPrice: quote.selectedPlan.price ?? undefined,
                selectedAddOns: quote.selectedAddOns,
                estimatedTotal: quote.estimatedTotal,
            },
            project: {
                description: getFormValue(projectFormData, 'project-description'),
                meetingDate: getFormValue(projectFormData, 'date'),
            },
            metadata: {
                pagePath: window.location.pathname,
                userAgent: navigator.userAgent,
            },
            website: getFormValue(contactFormData, 'website'),
        };

        setSubmitting(true);
        setSubmitStatus('Registrando tu solicitud...', 'neutral');

        try {
            const response = await fetch('/api/leads', {
                method: 'POST',
                headers: {
                    'content-type': 'application/json',
                },
                body: JSON.stringify(payload),
            });
            const result = await response.json().catch(() => null);

            if (!response.ok || !result?.ok) {
                throw new Error(result?.error || 'No se pudo registrar la solicitud.');
            }

            setSubmitStatus('Solicitud enviada. Te contactaremos pronto.', 'success');

            window.setTimeout(() => {
                resetQuoteModal();
                setSubmitStatus('', 'neutral');
                closeQuoteModal();
            }, 900);
        } catch (error) {
            setSubmitStatus(
                error instanceof Error ? error.message : 'No se pudo registrar la solicitud.',
                'error',
            );
        } finally {
            setSubmitting(false);
        }
    }

    submitButton?.addEventListener('click', (event) => {
        event.preventDefault();
        submitLead();
    });
</script>
