---
import { services } from "@/core/ServicesData";

const servicesWithAddOns = services.map((service) => ({
    id: service.id,
    title: service.title,
    addOns: [...(service.addOns || [])].sort((a, b) => a.name.localeCompare(b.name)),
}));
---

<div class="px-5 md:px-10 py-5 flex flex-col gap-y-5">
    <!-- Title -->
    <div class="space-y-2">
        <h3 class="text-lg text-white font-medium">Servicios adicionales</h3>
        <p class="text-sm text-neutral-300">
            Selecciona extras recomendados para
            <span id="additional-services-current-service">el servicio elegido</span>.
        </p>
    </div>

    <!-- Add Services -->
    <div class="space-y-3" id="services-container">
        <p id="additional-services-empty" class="text-sm text-neutral-400 italic">
            Elige un plan para ver servicios adicionales relacionados.
        </p>
        {
            servicesWithAddOns.map((service) => (
                <div
                    class="add-ons-group hidden flex-wrap items-center gap-2"
                    data-add-ons-service-id={service.id}
                    data-add-ons-service-title={service.title}
                >
                    {
                        service.addOns.map((addOn, index) => (
                            <button
                                class="service-btn px-3 py-2 rounded-lg border border-white/10 bg-white/5 text-xs text-white hover:bg-white/10 transition-colors flex items-center gap-2"
                                data-service-id={`${service.id}-${index}`}
                                data-service-name={addOn.name}
                                data-service-price={addOn.price}
                            >
                                <span>{addOn.name} - ${addOn.price}</span>

                                {/* Icon X - shown on hover when selected */}
                                <span class="icon-x hidden">
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="16"
                                        height="16"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        class="lucide lucide-x"
                                    >
                                        <path d="M18 6 6 18" />
                                        <path d="m6 6 12 12" />
                                    </svg>
                                </span>

                                {/* Icon Check - shown when selected */}
                                <span class="icon-check hidden">
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="16"
                                        height="16"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        class="lucide lucide-check"
                                    >
                                        <path d="M20 6 9 17l-5-5" />
                                    </svg>
                                </span>
                            </button>
                        ))
                    }
                </div>
            ))
        }
    </div>

    <!-- Buttons -->
    <div class="flex gap-x-2">
        <button
            type="button"
            class="w-full py-2.5 bg-white/5 text-white rounded-lg text-sm font-medium hover:bg-white/10 transition-colors"
        >
            Anterior
        </button>
        <button
            type="button"
            id="quote-submit-button"
            class="w-full py-2.5 bg-primary text-white rounded-lg text-sm font-medium hover:bg-primary-dark transition-colors"
        >
            Enviar
        </button>
    </div>

    <p id="quote-submit-status" class="hidden text-sm" role="status" aria-live="polite"></p>
</div>

<style>
    .service-btn {
        position: relative;
    }

    /* Hide icons by default */
    .icon-x,
    .icon-check {
        display: none;
    }

    /* Show check icon when selected */
    .service-btn.selected .icon-check {
        display: inline-flex;
    }

    /* Hide check and show X icon on hover when selected */
    .service-btn.selected:hover .icon-check {
        display: none;
    }

    .service-btn.selected:hover .icon-x {
        display: inline-flex;
    }

    /* Add visual feedback when selected */
    .service-btn.selected {
        background: rgba(255, 255, 255, 0.15);
        border-color: rgba(255, 255, 255, 0.3);
    }
</style>

<script>
    // Initialize services state
    const servicesState = new Map();
    let activeServiceId = '';

    // Get all service buttons
    const serviceButtons = document.querySelectorAll('.service-btn');
    const addOnGroups = document.querySelectorAll('.add-ons-group');
    const emptyMessage = document.getElementById('additional-services-empty');
    const currentServiceLabel = document.getElementById('additional-services-current-service');

    serviceButtons.forEach((button) => {
        const serviceId = button.getAttribute('data-service-id');
        const serviceName = button.getAttribute('data-service-name');
        const servicePrice = button.getAttribute('data-service-price');

        // Initialize state
        servicesState.set(serviceId, {
            name: serviceName,
            price: parseFloat(servicePrice || '0'),
            selected: false
        });

        // Add click event listener
        button.addEventListener('click', (e) => {
            e.preventDefault();
            
            const currentState = servicesState.get(serviceId);
            
            // Toggle selected state
            currentState.selected = !currentState.selected;
            servicesState.set(serviceId, currentState);

            // Update UI
            if (currentState.selected) {
                button.classList.add('selected');
                
                // Add to quote summary
                if ((window as any).quoteManager && serviceName) {
                    (window as any).quoteManager.addService(serviceName, parseFloat(servicePrice || '0'));
                }
            } else {
                button.classList.remove('selected');
                
                // Remove from quote summary
                if ((window as any).quoteManager && serviceName) {
                    (window as any).quoteManager.removeService(serviceName);
                }
            }
        });
    });

    // Export state for form submission (optional)
    (window as any).getSelectedServices = () => {
        return Array.from(servicesState.values()).filter(s => s.selected);
    };

    // Export reset function to clear all selections
    (window as any).resetServices = () => {
        // Reset all states to false
        servicesState.forEach((value, key) => {
            value.selected = false;
            servicesState.set(key, value);
        });

        // Remove 'selected' class from all buttons
        serviceButtons.forEach((button) => {
            button.classList.remove('selected');
        });
    };

    (window as any).setAdditionalServicesForService = (serviceId: string) => {
        activeServiceId = serviceId;
        (window as any).resetServices();

        let hasVisibleGroup = false;
        let activeServiceTitle = '';

        addOnGroups.forEach((group) => {
            const groupServiceId = group.getAttribute('data-add-ons-service-id') || '';
            const shouldShowGroup = groupServiceId === activeServiceId;

            group.classList.toggle('hidden', !shouldShowGroup);
            group.classList.toggle('flex', shouldShowGroup);

            if (shouldShowGroup) {
                hasVisibleGroup = true;
                activeServiceTitle = group.getAttribute('data-add-ons-service-title') || '';
            }
        });

        if (emptyMessage) {
            emptyMessage.classList.toggle('hidden', hasVisibleGroup);
            emptyMessage.textContent = hasVisibleGroup
                ? ''
                : 'Este servicio no tiene adicionales configurados por ahora.';
        }

        if (currentServiceLabel) {
            currentServiceLabel.textContent = activeServiceTitle || 'el servicio elegido';
        }
    };
</script>
