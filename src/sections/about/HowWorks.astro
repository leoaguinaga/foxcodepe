---
import ProcessStepCard from "@/components/ProcessStepCard.astro";
import { processData } from "@/core/ProcessSteepData"; 
---

<section class="py-20 max-xl:px-5">
    <div class="space-y-10 w-full max-w-5xl text-center mx-auto">
        <h3
            class="text-3xl lg:text-4xl font-medium text-white max-w-3xl mx-auto"
        >
            Cómo transformamos tu <span class="text-primary">idea</span> en realidad
        </h3>

        <!-- Steeps -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
            {processData.map((step, index) => (
                <ProcessStepCard 
                    icon={step.icon}
                    title={step.title}
                    description={step.description}
                    number={index + 1}
                />
            ))}
        </div>
    </div>
</section>
