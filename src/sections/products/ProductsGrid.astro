---
import { products } from "@/core/ProductsData";
---

<section
    id="productos"
    class="w-full grid gap-y-20 md:gap-y-40 py-10 max-w-5xl mx-auto max-lg:px-5"
>
    {
        products.map((product, index) => {
            const isEven = index % 2 === 0;
            const textAlign = isEven ? "" : "md:text-end";
            const gridOrder = isEven ? "" : "md:flex-row-reverse";
            const activeModule = product.modules[0];

            return (
                <article class="grid md:grid-cols-2 gap-5 md:gap-x-5 md:gap-y-10">
                    <div
                        id={product.id}
                        class={`flex flex-col gap-y-5 md:col-span-2 max-w-3xl ${isEven ? "" : "md:ml-auto"} ${textAlign}`}
                    >
                        <div
                            class={`px-3 py-2.5 flex items-center gap-x-1.5 text-xs rounded-full bg-primary font-semibold w-fit uppercase tracking-wider ${isEven ? "" : "md:ml-auto"}`}
                        >
                            <p class="leading-none">{product.category}</p>
                        </div>
                        <h3 class="text-3xl md:text-4xl font-medium">
                            {product.title}
                        </h3>
                        <p class="text-neutral-300 max-md:text-sm">
                            {product.description}
                        </p>
                    </div>

                    <div class={`flex flex-col md:flex-row gap-5 md:col-span-2 ${gridOrder}`}>
                        <div
                            class="product-module-carousel rounded-xl overflow-hidden bg-white/5 grid flex-1 border border-white/10"
                            data-product-carousel
                        >
                            <!-- Preview -->
                            <div class="h-66 bg-white/5 flex items-center justify-center p-4">
                                <img
                                    src={activeModule.image.src}
                                    alt={activeModule.title}
                                    class="rounded-lg max-h-full max-w-full object-contain transition-opacity duration-300"
                                    data-module-preview-image
                                />
                            </div>

                            <div class="flex items-center justify-center gap-x-2 p-4 pb-0">
                                {product.modules.map((module, moduleIndex) => (
                                    <button
                                        type="button"
                                        class={`product-module-trigger size-10 rounded-md border bg-white/5 transition hover:border-primary/70 flex items-center justify-center ${moduleIndex === 0 ? "border-primary" : "border-white/10"}`}
                                        aria-label={`Ver módulo ${module.title}`}
                                        data-module-trigger
                                        data-module-index={moduleIndex}
                                        data-module-title={module.title}
                                        data-module-description={module.description}
                                        data-module-image={module.image.src}
                                    >
                                        <img
                                            src={module.icon}
                                            alt=""
                                            class="size-5 object-contain opacity-80"
                                            loading="lazy"
                                        />
                                    </button>
                                ))}
                            </div>

                            <div class="p-4 space-y-2">
                                <h4 class="product-module-title text-white text-lg" data-module-active-title>
                                    {activeModule.title}
                                </h4>
                                <p class="product-module-description text-neutral-300 text-sm" data-module-active-description>
                                    {activeModule.description}
                                </p>
                            </div>
                        </div>

                        <div class="rounded-xl overflow-hidden bg-linear-to-b from-white/1 to-white/5 h-118 flex-1 border border-white/10">
                            <div class="p-5 space-y-2">
                                <h4 class="text-white text-lg">{product.secondaryFeature.title}</h4>
                                <p class="text-neutral-300 text-sm">
                                    {product.secondaryFeature.description}
                                </p>
                            </div>

                            <div class="h-fit overflow-hidden flex items-center justify-center">
                                <img
                                    src={product.userPersona.image.src}
                                    alt={product.userPersona.alt}
                                    class="max-h-full max-w-full object-contain animate-float"
                                />
                            </div>
                        </div>
                    </div>
                </article>
            );
        })
    }
</section>

<script>
    const carousels = document.querySelectorAll('[data-product-carousel]');

    carousels.forEach((carousel) => {
        const image = carousel.querySelector('[data-module-preview-image]') as HTMLImageElement | null;
        const title = carousel.querySelector('[data-module-active-title]') as HTMLElement | null;
        const description = carousel.querySelector('[data-module-active-description]') as HTMLElement | null;
        const triggers = Array.from(
            carousel.querySelectorAll('[data-module-trigger]'),
        ) as HTMLButtonElement[];
        let activeIndex = 0;
        let intervalId: number | undefined;

        function setActiveModule(index: number) {
            const trigger = triggers[index];

            if (!trigger || !image || !title || !description) {
                return;
            }

            activeIndex = index;
            image.classList.add('opacity-0');

            window.setTimeout(() => {
                image.src = trigger.dataset.moduleImage || image.src;
                image.alt = trigger.dataset.moduleTitle || '';
                title.textContent = trigger.dataset.moduleTitle || '';
                description.textContent = trigger.dataset.moduleDescription || '';
                image.classList.remove('opacity-0');
            }, 150);

            triggers.forEach((button, buttonIndex) => {
                button.classList.toggle('border-primary', buttonIndex === activeIndex);
                button.classList.toggle('border-white/10', buttonIndex !== activeIndex);
            });
        }

        function startAutoPlay() {
            window.clearInterval(intervalId);
            intervalId = window.setInterval(() => {
                setActiveModule((activeIndex + 1) % triggers.length);
            }, 5500);
        }

        triggers.forEach((trigger, index) => {
            trigger.addEventListener('click', () => {
                setActiveModule(index);
                startAutoPlay();
            });
        });

        if (triggers.length > 1) {
            startAutoPlay();
        }
    });
</script>
